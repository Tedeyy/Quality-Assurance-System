create database quality_assurance_system;
use quality_assurance_system;

CREATE TABLE divisions (
    division_id INT AUTO_INCREMENT PRIMARY KEY,
    acronym TEXT NOT NULL,
    name TEXT NOT NULL,
    parent_division_id INT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (parent_division_id) REFERENCES divisions(division_id)
);

CREATE TABLE divisions_offices (
    office_id INT AUTO_INCREMENT PRIMARY KEY,
    acronym TEXT NOT NULL,
    name TEXT NOT NULL,
    division_id INT,
    parent_office_id INT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (division_id) REFERENCES divisions(division_id),
    FOREIGN KEY (parent_office_id) REFERENCES divisions_offices(office_id)
);

CREATE TABLE divisions_sections (
    section_id INT AUTO_INCREMENT PRIMARY KEY,
    acronym TEXT NOT NULL,
    name TEXT NOT NULL,
    office_id INT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (office_id) REFERENCES divisions_offices(office_id)
);

CREATE TABLE divisions_programs (
    program_id INT AUTO_INCREMENT PRIMARY KEY,
    acronym TEXT NOT NULL,
    name TEXT NOT NULL,
    section_id INT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (section_id) REFERENCES divisions_sections(section_id)
);

CREATE TABLE users (
    user_id INTEGER PRIMARY KEY AUTO_INCREMENT,
    google_id TEXT UNIQUE,
    google_access_token TEXT,
    google_refresh_token TEXT,
    email TEXT UNIQUE NOT NULL,
    password TEXT NOT NULL, -- encypted
    fname TEXT NOT NULL,
    lname TEXT NOT NULL,
    birthdate DATE,
    gender ENUM('Male', 'Female', 'Others'),
    address TEXT,
    province TEXT,
    city TEXT,
    barangay TEXT,
    contact_number VARCHAR(11),
    division_id INT,
    office_id INT,
    position TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (division_id) REFERENCES divisions(division_id),
    FOREIGN KEY (office_id) REFERENCES divisions_offices(office_id)
);

CREATE TABLE accreditations(
    accreditation_id INT AUTO_INCREMENT PRIMARY KEY,
    code TEXT NOT NULL,
    name TEXT NOT NULL,
    description TEXT,
    deadline DATE,
    status ENUM ('In Progress', 'Completed', 'Inactive'),
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE accreditation_categories(
    category_id INT AUTO_INCREMENT PRIMARY KEY,
    accreditation_id INT,
    parent_category_id INT DEFAULT NULL,
    name TEXT NOT NULL,
    FOREIGN KEY (accreditation_id) REFERENCES accreditations(accreditation_id) ON DELETE CASCADE,
    FOREIGN KEY (parent_category_id) REFERENCES accreditation_categories(category_id) ON DELETE CASCADE,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE accreditation_requirement(
    requirement_id INT AUTO_INCREMENT PRIMARY KEY,
    category_id INT,
    name TEXT NOT NULL,
    codename TEXT,
    parent_requirement_id INT DEFAULT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (category_id) REFERENCES accreditation_categories(category_id) ON DELETE CASCADE,
    FOREIGN KEY (parent_requirement_id) REFERENCES accreditation_requirement(requirement_id) ON DELETE CASCADE
);

CREATE TABLE accreditation_requirement_submissions (
    submission_id INT AUTO_INCREMENT PRIMARY KEY,
    requirement_id INT NOT NULL,
    division_id INT NOT NULL,
    office_id INT NOT NULL,
    user_id INT NOT NULL,
    status ENUM('Pending', 'Disapproved', 'Approved') DEFAULT 'Pending',
    google_drive_file_id TEXT,
    google_drive_link TEXT,
    file_path TEXT,
    remarks TEXT,
    marked_by INT,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (requirement_id) REFERENCES accreditation_requirement(requirement_id),
    FOREIGN KEY (division_id) REFERENCES divisions(division_id),
    FOREIGN KEY (office_id) REFERENCES divisions_offices(office_id),
    FOREIGN KEY (user_id) REFERENCES users(user_id),
    FOREIGN KEY (marked_by) REFERENCES users(user_id)
);

CREATE TABLE user_login(
    login_id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    login_time DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

CREATE TABLE user_activity(
    activity_id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    activity_description TEXT,
    activity_time DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

CREATE TABLE news(
    news_id INT AUTO_INCREMENT PRIMARY KEY,
    title TEXT NOT NULL,
    content TEXT NOT NULL,
    event_date DATE NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE SDGs (
    sdg_id INT AUTO_INCREMENT PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

CREATE TABLE activities(
    activity_id INT PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT NOT NULL,
    request_email_link TEXT,
    email_link TEXT,
    requesting_office_id INT,
    speaker VARCHAR(255),
    organizer VARCHAR(255),
    target_participants TEXT,
    number_of_participants INT,
    eventvenue TEXT,
    eventdate DATE,
    eventstatus ENUM('Pending', 'Ongoing', 'Completed') DEFAULT 'Pending',
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (requesting_office_id) REFERENCES divisions_offices(office_id) 
);

CREATE TABLE activity_sdgs (
    activity_id INT,
    sdg_id INT,
    PRIMARY KEY (activity_id, sdg_id),
    FOREIGN KEY (activity_id) REFERENCES activities(activity_id) ON DELETE CASCADE,
    FOREIGN KEY (sdg_id) REFERENCES SDGs(sdg_id) ON DELETE CASCADE
);

CREATE TABLE activity_target_groups (
    activity_id INT,
    target_group VARCHAR(100),
    PRIMARY KEY (activity_id, target_group),
    FOREIGN KEY (activity_id) REFERENCES activities(activity_id) ON DELETE CASCADE
);

CREATE TABLE activity_evaluation(
    evaluation_id INT AUTO_INCREMENT PRIMARY KEY,
    activity_id INT,
    ame_form_link TEXT,
    number_of_respondents INT,
    response_rate FLOAT,
    complaints TEXT,
    suggestions_for_improvement TEXT,
    published_options ENUM('Open', 'Closed'),
    date_released DATE,
    deadline DATE, -- 20 Working Days after release
    evaluation_status ENUM('Pending','In Progress', 'Completed', 'Overdue') DEFAULT 'Pending',
    justification_letter TEXT, -- If applicable
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (activity_id) REFERENCES activities(activity_id)
);

CREATE TABLE activity_statistics(
    statistics_id INT AUTO_INCREMENT PRIMARY KEY,
    evaluation_id INT,
    osr FLOAT, --Overall Service Rating
    osr_wa FLOAT, --Weighted Average (OSR)	
    peor FLOAT, --Presenter Effectiveness /Organizer Rating	
    peor_wa FLOAT, --Weighted Average (PE/OOR)	
    pam FLOAT, --Program and Methodology	
    pam_wa FLOAT, --Weighted Average (PAM)	
    pamlss FLOAT, --Program/Activity Management/ Logistics and Support Services	
    pamlss_wa FLOAT, --Weighted Average (P/AM)	
    oe FLOAT, --Overall Experience	
    oe_wa FLOAT, --Weighted Average (OE)	
    overall_average FLOAT, --Overall Average	
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (evaluation_id) REFERENCES activity_evaluation(evaluation_id)
);

CREATE TABLE activity_statistics_others(
    otherstat_id INT AUTO_INCREMENT PRIMARY KEY,
    evaluation_id INT,
    gender_distribution VARCHAR(255),
    age_distribution VARCHAR(255),
    unit_distribution VARCHAR(255),
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (evaluation_id) REFERENCES activity_evaluation(evaluation_id)
);

CREATE TABLE activity_speaker_rating(
    speaker_id INT AUTO_INCREMENT PRIMARY KEY,
    evaluation_id INT,
    name VARCHAR(255) NOT NULL,
    eandd FLOAT, --Expertise and Delivery
    mot FLOAT, --Mastery of Topic
    iae FLOAT, --Interaction and Engagement
    gi FLOAT, --General Impact
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (evaluation_id) REFERENCES activity_evaluation(evaluation_id)
);

CREATE TABLE activity_organizer_rating(
    organizer_id INT AUTO_INCREMENT PRIMARY KEY,
    evaluation_id INT,
    name VARCHAR(255) NOT NULL,
    eandd FLOAT, --Expertise and Delivery
    mot FLOAT, --Mastery of Topic
    iae FLOAT, --Interaction and Engagement
    gi FLOAT, --General Impact
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (evaluation_id) REFERENCES activity_evaluation(evaluation_id)
); --still unsure, needs verification